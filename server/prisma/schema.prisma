// Prisma Schema for MediPing
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  password_hash    String?   // Nullable for OAuth users
  phone_number     String?   @unique
  profile_image_url String?
  auth_provider    String    @default("email") // email, google, apple, phone
  role             String    @default("user") // user, admin, caregiver
  timezone         String?   @default("UTC")
  preferred_notification_sound String?
  is_verified      Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  // Relations
  profile          UserProfile?
  medications      Medication[]
  dose_logs        DoseLog[]
  dependents       Dependent[]
  caregiver_relationships CaregiverRelationship[] @relation("Caregiver")
  care_recipients  CaregiverRelationship[] @relation("CareRecipient")
  health_logs      HealthLog[]
  refills          Refill[]
  notifications    Notification[]
  vitals_logs      VitalsLog[]
  appointments     Appointment[]

  @@map("users")
}

model UserProfile {
  id                  String   @id @default(uuid())
  user_id             String   @unique
  age                 Int?
  gender              String?
  onboarding_completed Boolean @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Dependent {
  id                  String   @id @default(uuid())
  user_id             String
  name                String
  age                 Int?
  gender              String?
  relationship        String   // child, elderly, pet
  timezone            String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  medications         Medication[]

  @@map("dependents")
}

model Medication {
  id                  String   @id @default(uuid())
  user_id             String?
  dependent_id        String?
  name                String
  dosage              String   // e.g., "10mg", "2 tablets"
  medication_type     String?  @default("tablet") // tablet, pill, syrup, injection, etc.
  frequency           String   // daily, hourly, every X days
  times_per_day       Int      @default(1)
  times_of_day        Json     // Array of times, e.g., ["08:00", "20:00"]
  start_date          DateTime
  end_date            DateTime?
  is_continuous       Boolean  @default(true)
  food_instructions   String?
  notes               String?
  photo_url           String?
  quantity_remaining  Int?
  low_stock_threshold Int?     @default(7) // days
  reason_for_treatment String? // Free text field for treatment reason
  schedule_pattern    String?  @default("daily") // daily, weekly, alternating
  schedule_pattern_data Json?  // For alternating patterns: {type: "left_right", current: "left"}
  injection_site_data Json?    // For injection tracking: {site: "left_arm", date: "..."}
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user                User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  dependent           Dependent? @relation(fields: [dependent_id], references: [id], onDelete: Cascade)
  dose_logs           DoseLog[]
  refills             Refill[]

  @@map("medications")
}

model DoseLog {
  id                  String   @id @default(uuid())
  user_id             String
  medication_id       String
  scheduled_time      DateTime
  status              String   // taken, missed, skipped
  taken_time          DateTime?
  notes               String?
  injection_site      String?  // For injection tracking: "left_arm", "right_thigh", etc.
  created_at          DateTime @default(now())

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  medication          Medication @relation(fields: [medication_id], references: [id], onDelete: Cascade)

  @@map("dose_logs")
  @@index([user_id, scheduled_time])
}

model Refill {
  id                  String   @id @default(uuid())
  user_id             String
  medication_id       String
  quantity            Int
  refill_date         DateTime
  notes               String?
  created_at          DateTime @default(now())

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  medication          Medication @relation(fields: [medication_id], references: [id], onDelete: Cascade)

  @@map("refills")
}

model HealthLog {
  id                  String   @id @default(uuid())
  user_id             String
  log_type            String   // symptom, vital, water_intake, exercise
  data                Json     // Flexible JSON for different log types
  recorded_at         DateTime @default(now())
  created_at          DateTime @default(now())

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("health_logs")
  @@index([user_id, recorded_at])
}

model VitalsLog {
  id                  String   @id @default(uuid())
  user_id             String
  weight               Float?   // kg
  blood_pressure_systolic Int?  // mmHg
  blood_pressure_diastolic Int? // mmHg
  blood_glucose       Float?   // mg/dL
  heart_rate           Int?     // bpm
  temperature         Float?   // Celsius
  notes               String?
  recorded_at         DateTime @default(now())
  created_at          DateTime @default(now())

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("vitals_logs")
  @@index([user_id, recorded_at])
}

model Appointment {
  id                  String   @id @default(uuid())
  user_id             String
  title               String
  doctor_name         String?
  appointment_type    String?  // checkup, followup, specialist, etc.
  scheduled_time      DateTime
  location            String?
  notes               String?
  reminder_minutes    Int?     @default(60) // Minutes before to remind
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("appointments")
  @@index([user_id, scheduled_time])
}

model CaregiverRelationship {
  id                  String   @id @default(uuid())
  caregiver_id        String
  care_recipient_id   String
  status              String   @default("pending") // pending, accepted, rejected
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  caregiver           User     @relation("Caregiver", fields: [caregiver_id], references: [id], onDelete: Cascade)
  care_recipient      User     @relation("CareRecipient", fields: [care_recipient_id], references: [id], onDelete: Cascade)

  @@unique([caregiver_id, care_recipient_id])
  @@map("caregiver_relationships")
}

model Notification {
  id                  String   @id @default(uuid())
  user_id             String
  type                String   // reminder, refill, adherence, caregiver_alert
  title               String
  message             String
  data                Json?
  is_read             Boolean  @default(false)
  created_at          DateTime @default(now())

  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([user_id, is_read])
}

