{
  "expo": {
    "name": "MediPing",
    "slug": "mediping",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "mediping",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mediping.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "MediPing needs access to your photo library to allow you to add photos of your medications. For example, you can take a picture of your medication bottle or pill container to help you identify and track your medications more easily. These photos are stored securely on your device and are only used within the app to help you manage your medication schedule.",
        "NSPhotoLibraryAddUsageDescription": "MediPing needs access to save medication photos to your photo library. For example, if you want to save a photo of your medication for reference outside the app, we'll save it to your photo library with your permission.",
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.mediping.app.medication-background-task"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mediping.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "mediping"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "@clerk/expo",
        {
          "appleSignIn": true
        }
      ],
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "android": {
            "googleServicesFile": "./google-services.json",
            "gradleProperties": {
              "android.useAndroidX": "true",
              "android.enableJetifier": "true"
            }
          },
          "ios": {
            "googleServicesFile": "./GoogleService-Info.plist",
            "useFrameworks": "static",
            "podfileProperties": {
              "use_modular_headers!": true
            },
            "buildReactNativeFromSource": true
          }
        }
      ],
      "./plugins/withRemoveAdIdPermission.js",
      "expo-web-browser"
    ],
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "de46564e-f030-4d56-8e36-a6bbfb207ee8"
      }
    }
  }
}
